# Copy this file to ".env" and fill in real values. Never commit the real .env file.

# --- Folders used by the extraction pipeline ---
INPUT_PDF_DIR=./input_pdfs
OUTPUT_JSON_DIR=./output_json
OUTPUT_IMAGE_DIR=./output_images

# --- WordPress site the import pipeline will push content into ---
#
# Local development (LocalWP): WP_BASE_URL is the "Local site domain"
#   shown in LocalWP, e.g. https://lab-manual.local
# Production (Oracle Cloud Always Free VM): WP_BASE_URL is your domain
#   (or DDNS hostname) once DNS + Let's Encrypt are set up, e.g.
#   https://labname.duckdns.org - see "Part 1B: Hosting for free on
#   Oracle Cloud" in the README. Do not use the bare IP address here
#   long-term; Application Passwords need a real HTTPS certificate,
#   which Let's Encrypt cannot issue for a bare IP.
WP_BASE_URL=https://your-lab-site.example.com
WP_USERNAME=your_admin_or_editor_username
# Generate this from WordPress admin: Users > Profile > Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Whether to verify the site's TLS certificate. Leave this as "true" for
# Oracle Cloud (or any real host). Set to "false" ONLY for a LocalWP site
# whose self-signed certificate you haven't clicked "Trust" on in
# LocalWP's SSL tab - see the README's LocalWP section.
WP_VERIFY_SSL=true

# Copy this file to ".env" and fill in real values. Never commit the real .env file.

# --- Folders used by the extraction pipeline ---
INPUT_PDF_DIR=./input_pdfs
OUTPUT_JSON_DIR=./output_json
OUTPUT_IMAGE_DIR=./output_images

# --- WordPress site the import pipeline will push content into ---
WP_BASE_URL=https://your-lab-site.example.com
WP_USERNAME=your_admin_or_editor_username
# Generate this from WordPress admin: Users > Profile > Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
